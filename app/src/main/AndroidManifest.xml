<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for Claude CLI (traffic goes through CLI, not app directly) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required by NetworkMonitor (ConnectivityManager) to observe connectivity -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notification permission for foreground service (runtime request on API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service permission for keeping CLI process alive in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Specialized foreground service type permission for data sync -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".ClaudeMobileApplication"
        android:allowBackup="true"
        android:extractNativeLibs="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClaudeMobile">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.ClaudeMobile">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service for keeping Claude CLI processes alive in background -->
        <service
            android:name="com.claudemobile.core.bridge.service.ClaudeSessionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
